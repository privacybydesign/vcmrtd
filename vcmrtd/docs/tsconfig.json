{
  // This file is not used in compilation. It is here just for a nice editor experience.
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    // @docusaurus/tsconfig still sets the now-deprecated `baseUrl`; silence the
    // TS 6.0 deprecation warning until Docusaurus drops it (removed in TS 7.0).
    "ignoreDeprecations": "6.0"
  },
  "exclude": [".docusaurus", "build"]
}
